@model IEnumerable<CareerCraft.Shared.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "Gestion des Utilisateurs";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Créer un utilisateur</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Prénom</th>
            <th>Nom</th>
            <th>Genre</th>
            <th>Photo</th>
            <th>Infos</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.FirstName)</td>
            <td>@Html.DisplayFor(modelItem => item.LastName)</td>
            <td>@Html.DisplayFor(modelItem => item.Gender)</td>
            <td>
                @if (!string.IsNullOrEmpty(item.PortraitPath))
                {
                    <img src="@item.PortraitPath" alt="Portrait" style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%;" />
                }
            </td>
            <td>@item.UserInfos.Count()</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">Editer</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Supprimer</a>
            </td>
        </tr>
}
    </tbody>
</table>
